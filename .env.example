# ─── DIEPS Intent Engine — Environment Variables ───────────────
# Copy this file to .env and fill in the values.

# ─── Sui Network ───────────────────────────────────────────────
# Sui Mainnet RPC endpoint (default: public fullnode)
SUI_RPC_ENDPOINT=https://fullnode.mainnet.sui.io:443
# Optional API key for premium RPC providers
SUI_API_KEY=

# ─── LLM / OpenRouter ─────────────────────────────────────────
# OpenRouter API key for enhanced intent parsing
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Model to use (default: google/gemma-4-31b-it:free)
OPENROUTER_MODEL=google/gemini-2.5-flash

# ─── Oracle ────────────────────────────────────────────────────
# Pyth Hermes API URL (default: public endpoint)
PYTH_HERMES_URL=https://hermes.pyth.network

# ─── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
